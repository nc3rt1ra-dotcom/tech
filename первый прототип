<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Change Your Life</title>
  <style>
    /* === Japandi Minimalism === */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #f5f0eb;
      color: #4a4540;
      font-family: "Helvetica Neue", Arial, sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    .app {
      width: 100%;
      height: 100%;
      position: relative;
    }

    .stage {
      position: relative;
      width: 100%;
      height: 100%;
    }

    /* === Panels === */
    .panel {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 28px;
      opacity: 0;
      transform: translateX(30px);
      pointer-events: none;
      transition: opacity 0.5s ease, transform 0.5s ease;
      z-index: 1;
    }

    .panel.active {
      opacity: 1;
      transform: translateX(0);
      pointer-events: auto;
      z-index: 10;
    }

    .panel.leaving-left {
      opacity: 0;
      transform: translateX(-30px);
      z-index: 5;
    }

    .panel.leaving-right {
      opacity: 0;
      transform: translateX(30px);
      z-index: 5;
    }

    /* === Typography === */
    h1, h2, .eyebrow {
      font-family: Georgia, "Times New Roman", serif;
      letter-spacing: 0.02em;
    }

    h1 {
      font-weight: normal;
      font-size: clamp(2.4rem, 7vw, 5.2rem);
      line-height: 1.1;
      color: #2c2825;
    }

    h2 {
      font-weight: normal;
      font-size: clamp(1.8rem, 4.5vw, 3.2rem);
      line-height: 1.15;
      color: #2c2825;
    }

    .eyebrow {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.28em;
      color: #8a8279;
      font-family: "Helvetica Neue", Arial, sans-serif;
    }

    /* === Layout === */
    .center-box, .content-shell {
      width: min(100%, 780px);
      text-align: center;
    }

    .intro-box {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 22px;
    }

    /* === Buttons === */
    .choice-row {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .btn {
      border: 1px solid rgba(60,55,50,0.25);
      background: rgba(255,255,255,0.7);
      color: #2c2825;
      padding: 14px 28px;
      border-radius: 999px;
      font-size: 1rem;
      cursor: pointer;
      transition: transform 0.22s ease, background 0.22s ease, border-color 0.22s ease;
      backdrop-filter: blur(6px);
      position: relative;
      z-index: 100;
      text-decoration: none;
      display: inline-block;
    }

    .btn:hover {
      transform: translateY(-1px);
      background: rgba(255,255,255,0.9);
      border-color: rgba(60,55,50,0.45);
    }

    .btn-no {
      background: rgba(245,240,235,0.5);
      color: #6b655e;
    }

    .btn-no:hover {
      background: rgba(235,230,225,0.7);
      color: #4a4540;
    }

    /* === Poster & QR === */
    .poster-frame, .qr-frame {
      margin: 26px auto 0;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(60,55,50,0.18);
      background: rgba(255,255,255,0.6);
      box-shadow: 0 0 0 1px rgba(60,55,50,0.05) inset, 0 12px 40px rgba(60,55,50,0.08);
      backdrop-filter: blur(8px);
      overflow: hidden;
      border-radius: 14px;
    }

    .poster-frame {
      width: min(92vw, 740px);
      aspect-ratio: 16 / 9;
      cursor: pointer;
    }

    .poster-frame iframe {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }

    .qr-frame {
      width: min(92vw, 280px);
      aspect-ratio: 1 / 1;
      cursor: pointer;
      transition: transform 0.22s ease, box-shadow 0.22s ease;
    }

    .qr-frame:hover {
      transform: translateY(-2px);
      box-shadow: 0 0 0 1px rgba(60,55,50,0.05) inset, 0 16px 48px rgba(60,55,50,0.12);
    }

    .qr-frame img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
      padding: 16px;
    }

    .qr-link {
      display: inline-block;
      text-decoration: none;
    }

    .qr-btn {
      margin-top: 20px;
      display: inline-block;
    }

    /* === Sources === */
    .sources-shell { text-align: left; }

    .sources-list {
      margin-top: 22px;
      display: grid;
      gap: 14px;
    }

    .source-item {
      padding: 16px 18px;
      border-radius: 12px;
      border: 1px solid rgba(60,55,50,0.15);
      background: rgba(255,255,255,0.5);
      backdrop-filter: blur(6px);
      font-size: 0.95rem;
    }

    .source-item span { color: #8a8279; }

    /* === Arrows === */
    .arrow {
      position: fixed;
      top: 50%;
      transform: translateY(-50%);
      width: 46px;
      height: 46px;
      border-radius: 50%;
      border: 1px solid rgba(60,55,50,0.2);
      background: rgba(255,255,255,0.7);
      color: #2c2825;
      font-size: 2rem;
      line-height: 1;
      display: grid;
      place-items: center;
      cursor: pointer;
      z-index: 1000;
      transition: background 0.22s ease, transform 0.22s ease;
      backdrop-filter: blur(6px);
      pointer-events: auto;
    }

    .arrow:hover {
      background: rgba(255,255,255,0.95);
      transform: translateY(-50%) scale(1.04);
    }

    .left-arrow { left: 14px; }
    .right-arrow { right: 14px; }

    /* === Exit overlay === */
    .exit-overlay {
      position: fixed;
      inset: 0;
      display: grid;
      place-items: center;
      background: rgba(245,240,235,0.96);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
      z-index: 10000;
    }

    .exit-overlay.show {
      opacity: 1;
      pointer-events: auto;
    }

    .exit-card {
      text-align: center;
      padding: 26px;
      border: 1px solid rgba(60,55,50,0.18);
      border-radius: 14px;
      background: rgba(255,255,255,0.8);
      backdrop-filter: blur(8px);
    }

    .exit-card h2 {
      font-size: 1.9rem;
      color: #2c2825;
    }

    .exit-card p {
      color: #8a8279;
      margin: 8px 0 0;
    }

    /* === Mobile === */
    @media (max-width: 640px) {
      .panel { padding: 20px; }
      .arrow {
        width: 42px;
        height: 42px;
        font-size: 1.8rem;
      }
      h1 { max-width: 13ch; }
    }
  </style>
</head>
<body>
  <div class="app">
    <main class="stage" id="stage">

      <!-- Screen 1: Question -->
      <section class="panel active" data-panel="0">
        <div class="center-box intro-box">
          <p class="eyebrow">A moment of honesty</p>
          <h1>Are you ready to change your life for the better?</h1>
          <div class="choice-row">
            <button class="btn btn-yes" id="yesBtn">Yes</button>
            <button class="btn btn-no" id="noBtn">No</button>
          </div>
        </div>
      </section>

      <!-- Screen 2: Poster -->
      <section class="panel" data-panel="1">
        <div class="content-shell">
          <p class="eyebrow">Step 1</p>
          <h2>Explore our poster more closely</h2>
          <div class="poster-frame" id="posterFrame">
            <iframe
              loading="lazy"
              src="https://www.canva.com/design/DAHKI_tNXz0/KZ4FiyDvodhDw1QANAD0Pw/view?embed"
              allowfullscreen="allowfullscreen"
              allow="fullscreen">
            </iframe>
          </div>
        </div>
      </section>

      <!-- Screen 3: QR -->
      <section class="panel" data-panel="2">
        <div class="content-shell">
          <p class="eyebrow">Step 2</p>
          <h2>Take the test and earn a reward</h2>
          <a href="https://docs.google.com/forms/d/e/1FAIpQLSfAn1PttOrvAasGtmxMgOgE11do-vUpRqGv3RBKdl26O7Nbdg/viewform?usp=publish-editor" target="_blank" rel="noopener noreferrer" class="qr-link">
            <div class="qr-frame" id="qrFrame">
              <img 
                src="https://api.qrserver.com/v1/create-qr-code/?size=280x280&data=https://docs.google.com/forms/d/e/1FAIpQLSfAn1PttOrvAasGtmxMgOgE11do-vUpRqGv3RBKdl26O7Nbdg/viewform?usp=publish-editor" 
                alt="QR Code"
              />
            </div>
          </a>
          <a href="https://docs.google.com/forms/d/e/1FAIpQLSfAn1PttOrvAasGtmxMgOgE11do-vUpRqGv3RBKdl26O7Nbdg/viewform?usp=publish-editor" target="_blank" rel="noopener noreferrer" class="btn qr-btn">Go to Test</a>
        </div>
      </section>

      <!-- Screen 4: Sources -->
      <section class="panel" data-panel="3">
        <div class="content-shell sources-shell">
          <p class="eyebrow">Final step</p>
          <h2>Sources</h2>
          <div class="sources-list">
            <div class="source-item">Source 1: <span>[NASK National Research Institute. (2025). Nastolatki. Raport z ogólnopolskiego badania uczniów i rodziców [Teenagers. Report from a nationwide survey of students and parents].]</span></div>
            <div class="source-item">Source 2: <span>[add link]</span></div>
            <div class="source-item">Source 3: <span>[add link]</span></div>
            <div class="source-item">Source 4: <span>[add link]</span></div>
          </div>
        </div>
      </section>

    </main>
  </div>

  <!-- Navigation arrows - outside panels to avoid z-index issues -->
  <button class="arrow left-arrow" id="prevBtn" aria-label="Previous">&#8249;</button>
  <button class="arrow right-arrow" id="nextBtn" aria-label="Next">&#8250;</button>

  <div class="exit-overlay" id="exitOverlay" aria-hidden="true">
    <div class="exit-card">
      <h2>Maybe another time.</h2>
      <p>The page will close now.</p>
    </div>
  </div>

  <script>
    (function() {
      'use strict';

      var panels = Array.from(document.querySelectorAll('.panel'));
      var nextBtn = document.getElementById('nextBtn');
      var prevBtn = document.getElementById('prevBtn');
      var yesBtn = document.getElementById('yesBtn');
      var noBtn = document.getElementById('noBtn');
      var exitOverlay = document.getElementById('exitOverlay');
      var posterFrame = document.getElementById('posterFrame');
      var index = 0;
      var startX = 0;

      function updateArrows() {
        if (index === 0) {
          prevBtn.style.opacity = '0';
          prevBtn.style.pointerEvents = 'none';
        } else {
          prevBtn.style.opacity = '1';
          prevBtn.style.pointerEvents = 'auto';
        }
        if (index === panels.length - 1) {
          nextBtn.style.opacity = '0';
          nextBtn.style.pointerEvents = 'none';
        } else {
          nextBtn.style.opacity = '1';
          nextBtn.style.pointerEvents = 'auto';
        }
      }

      function showPanel(nextIndex, dir) {
        if (nextIndex < 0 || nextIndex >= panels.length || nextIndex === index) return;

        var current = panels[index];
        var next = panels[nextIndex];

        current.classList.remove('active', 'leaving-left', 'leaving-right');
        next.classList.remove('leaving-left', 'leaving-right');
        next.classList.add('active');
        current.classList.add(dir === 'next' ? 'leaving-left' : 'leaving-right');

        index = nextIndex;
        updateArrows();

        setTimeout(function() {
          current.classList.remove('leaving-left', 'leaving-right');
        }, 500);
      }

      function closePage() {
        exitOverlay.classList.add('show');
        setTimeout(function() {
          window.close();
          document.body.innerHTML = '<div style="display:grid;place-items:center;height:100vh;background:#f5f0eb;color:#4a4540;font-family:Arial,sans-serif;text-align:center;padding:24px;"><div><h2 style="margin:0 0 12px;font-family:Georgia,serif;">Maybe another time.</h2><p style="margin:0;color:#8a8279;">You can close this tab now.</p></div></div>';
        }, 250);
      }

      nextBtn.addEventListener('click', function() {
        showPanel(index + 1, 'next');
      });

      prevBtn.addEventListener('click', function() {
        showPanel(index - 1, 'prev');
      });

      yesBtn.addEventListener('click', function() {
        showPanel(1, 'next');
      });

      noBtn.addEventListener('click', function() {
        closePage();
      });

      posterFrame.addEventListener('click', function() {
        window.open('https://www.canva.com/design/DAHKI_tNXz0/KZ4FiyDvodhDw1QANAD0Pw/view?utm_content=DAHKI_tNXz0&utm_campaign=designshare&utm_medium=embeds&utm_source=link', '_self');
      });

      document.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowRight') showPanel(index + 1, 'next');
        if (e.key === 'ArrowLeft') showPanel(index - 1, 'prev');
        if (e.key === 'Escape') closePage();
      });

      var stage = document.getElementById('stage');

      stage.addEventListener('touchstart', function(e) {
        startX = e.changedTouches[0].clientX;
      }, { passive: true });

      stage.addEventListener('touchend', function(e) {
        var endX = e.changedTouches[0].clientX;
        var diff = endX - startX;
        if (Math.abs(diff) < 40) return;
        if (diff < 0) showPanel(index + 1, 'next');
        else showPanel(index - 1, 'prev');
      }, { passive: true });

      updateArrows();

    })();
  </script>
</body>
</html>
