<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Change Your Life</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #f5f0eb;
      color: #4a4540;
      font-family: "Helvetica Neue", Arial, sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    .app {
      width: 100%;
      height: 100%;
      position: relative;
    }

    .stage {
      position: relative;
      width: 100%;
      height: 100%;
    }

    .panel {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 28px;
      opacity: 0;
      transform: translateX(30px);
      pointer-events: none;
      transition: opacity 0.5s ease, transform 0.5s ease;
      z-index: 1;
    }

    .panel.active {
      opacity: 1;
      transform: translateX(0);
      pointer-events: auto;
      z-index: 10;
    }

    .panel.leaving-left {
      opacity: 0;
      transform: translateX(-30px);
      z-index: 5;
    }

    .panel.leaving-right {
      opacity: 0;
      transform: translateX(30px);
      z-index: 5;
    }

    h1, h2, .eyebrow {
      font-family: Georgia, "Times New Roman", serif;
      letter-spacing: 0.02em;
    }

    h1 {
      font-weight: normal;
      font-size: clamp(2.4rem, 7vw, 5.2rem);
      line-height: 1.1;
      color: #2c2825;
    }

    h2 {
      font-weight: normal;
      font-size: clamp(1.8rem, 4.5vw, 3.2rem);
      line-height: 1.15;
      color: #2c2825;
    }

    .eyebrow {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.28em;
      color: #8a8279;
      font-family: "Helvetica Neue", Arial, sans-serif;
    }

    .center-box, .content-shell {
      width: min(100%, 780px);
      text-align: center;
    }

    .intro-box {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 22px;
    }

    .choice-row {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .btn {
      border: 1px solid rgba(60,55,50,0.25);
      background: rgba(255,255,255,0.7);
      color: #2c2825;
      padding: 14px 28px;
      border-radius: 999px;
      font-size: 1rem;
      cursor: pointer;
      transition: transform 0.22s ease, background 0.22s ease, border-color 0.22s ease;
      backdrop-filter: blur(6px);
      position: relative;
      z-index: 100;
      text-decoration: none;
      display: inline-block;
      text-align: center;
    }

    .btn:hover {
      transform: translateY(-1px);
      background: rgba(255,255,255,0.9);
      border-color: rgba(60,55,50,0.45);
    }

    .btn-no {
      background: rgba(245,240,235,0.5);
      color: #6b655e;
    }

    .btn-no:hover {
      background: rgba(235,230,225,0.7);
      color: #4a4540;
    }

    .poster-frame, .qr-frame {
      margin: 26px auto 0;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(60,55,50,0.18);
      background: rgba(255,255,255,0.6);
      box-shadow: 0 0 0 1px rgba(60,55,50,0.05) inset, 0 12px 40px rgba(60,55,50,0.08);
      backdrop-filter: blur(8px);
      overflow: hidden;
      border-radius: 14px;
    }

    .poster-frame {
      width: min(92vw, 740px);
      aspect-ratio: 16 / 9;
      cursor: pointer;
    }

    .poster-frame iframe {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }

    .qr-shell {
      width: min(100%, 900px);
    }

    .qr-head {
      margin-bottom: 14px;
    }

    .qr-grid {
      margin-top: 14px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
      align-items: start;
    }

    .qr-item {
      text-align: center;
    }

    .qr-frame {
      width: min(100%, 140px);
      aspect-ratio: 1 / 1;
      cursor: pointer;
      transition: transform 0.22s ease, box-shadow 0.22s ease;
      margin-top: 0;
    }

    .qr-frame:hover {
      transform: translateY(-2px);
      box-shadow: 0 0 0 1px rgba(60,55,50,0.05) inset, 0 16px 48px rgba(60,55,50,0.12);
    }

    .qr-frame img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
      padding: 10px;
    }

    .qr-label {
      margin-top: 8px;
      font-size: 0.9rem;
      color: #4a4540;
    }

    .qr-version {
      display: none;
    }

    .qr-link {
      display: inline-block;
      text-decoration: none;
    }

